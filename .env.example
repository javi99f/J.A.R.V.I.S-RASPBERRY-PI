GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Audio and privacy. "wakeword" keeps room audio local until "Hey Jarvis".
# Use "continuous" only for troubleshooting, or "manual" for text/touch only.
WAKE_MODE=wakeword
WAKE_THRESHOLD=0.40
# One normal model peak activates immediately. Two weaker peaks within the
# phrase are also accepted, improving recognition without accepting one noise spike.
WAKE_CONFIRM_FRAMES=2
# Keep Silero VAD disabled by default: quiet USB microphones can otherwise be
# rejected before the local hey_jarvis model sees their audio.
WAKE_VAD_THRESHOLD=0
# Automatic gain is applied only to local wake-word detection.
WAKE_AUTO_GAIN=1
CONVERSATION_TIMEOUT_SECONDS=12
# After Jarvis finishes speaking, keep the contextual microphone gate open this long.
FOLLOWUP_LISTEN_SECONDS=5
VOICE_RMS_THRESHOLD=300
JARVIS_VOICE=Charon
INPUT_DEVICE=
OUTPUT_DEVICE=
APP_MODE=raspberry_pi
DISPLAY_ROTATION=left
DISPLAY_RESOLUTION=1024x600
LIVE_OPEN_TIMEOUT_SECONDS=45
# The Pi tries IPv4 first, then keeps the normal resolver as a fallback.
LIVE_IP_MODE=ipv4-first
LIVE_USE_SYSTEM_PROXY=0

# Public GitHub repository used by the built-in updater. Configure this once
# with the repository that will publish Jarvis Releases.
UPDATE_REPOSITORY=javi99f/J.A.R.V.I.S-RASPBERRY-PI
UPDATE_ALLOW_PRERELEASE=0

# Optional: replace this SHA-256 hash to change the local developer password.
# The shipped default corresponds to the initial password selected by the owner.
DEVELOPER_PASSWORD_SHA256=0294388c97bf9af0ffd74b35daf403e0c1d149b08f3f6f52c6bd43800b8de1c6

# Optional Bluetooth speaker. Leave empty to use the system default output.
BLUETOOTH_SPEAKER_MAC=

# Optional: enables Instagram/TikTok analytics through Zernio.
ZERNIO_API_KEY=your-zernio-api-key

# Optional: enables Home Assistant smart-home controls.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your-home-assistant-long-lived-access-token

# Optional Spotify playback on this Raspberry Pi. Run configure_spotify.py
# after installing Raspotify; never commit the real client secret or token cache.
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_DEVICE_NAME=JARVIS Raspberry Pi
SPOTIFY_DEVICE_ID=
SPOTIFY_CACHE_PATH=
